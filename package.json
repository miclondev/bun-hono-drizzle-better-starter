{
  "name": "bun-hono-drizzle-better-starter",
  "version": "1.0.0",
  "description": "A modern, high-performance backend API starter built with Bun, Hono, Drizzle ORM, and better-auth",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miclondev/bun-hono-drizzle-better-starter.git"
  },
  "author": "miclondev",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/miclondev/bun-hono-drizzle-better-starter/issues"
  },
  "homepage": "https://github.com/miclondev/bun-hono-drizzle-better-starter#readme",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint ./src ./tests ./scripts",
    "lint:fix": "biome lint --write ./src ./tests ./scripts",
    "format": "biome format ./src ./tests ./scripts",
    "format:fix": "biome format --write ./src ./tests ./scripts",
    "check": "biome check ./src ./tests ./scripts",
    "check:fix": "biome check --write ./src ./tests ./scripts",
    "setup:db": "bun run scripts/setup-db.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed": "bun run scripts/seed-db.ts",
    "test": "bun test",
    "test:api": "bun run scripts/test-api.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@hono/node-server": "^1.19.11",
    "better-auth": "^1.5.4",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.7",
    "joi": "^18.0.2",
    "postgres": "^3.4.8",
    "rss-parser": "^3.13.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@faker-js/faker": "^10.3.0",
    "@types/bun": "^1.3.10",
    "@types/uuid": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3"
  }
}