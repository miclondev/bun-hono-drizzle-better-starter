# Node environment
NODE_ENV=development
PORT=3005

# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=viralsak
DB_USER=postgres
DB_PASSWORD=postgres

# Better Auth Configuration
# Generate a secure secret: openssl rand -base64 32
BETTER_AUTH_SECRET="P75ZLjuEh0uAMubz8o4M9KqK4LLL"
BETTER_AUTH_URL="http://localhost:3005"

# Google OAuth (Optional)
# Get these from https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email Service (Optional - for password reset emails)
# Using Gmail:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
# Or using SendGrid:
# SENDGRID_API_KEY=your_sendgrid_api_key
# Or using Resend:
# RESEND_API_KEY=your_resend_api_key

# TikTok OAuth Configuration
# Get these from https://developers.tiktok.com
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=http://localhost:3005/api/v1/tiktok/oauth/callback
FRONTEND_URL=http://localhost:8080

# Anthropic API Configuration
# Get your API key from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key

# Stripe Configuration
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs (Create these in Stripe Dashboard)
# Subscription Plans - Monthly
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly_id
STRIPE_PRICE_CREATOR_MONTHLY=price_creator_monthly_id
STRIPE_PRICE_AGENCY_MONTHLY=price_agency_monthly_id

# Subscription Plans - Yearly
STRIPE_PRICE_STARTER_YEARLY=price_starter_yearly_id
STRIPE_PRICE_CREATOR_YEARLY=price_creator_yearly_id
STRIPE_PRICE_AGENCY_YEARLY=price_agency_yearly_id

# Credit Packages (One-time purchases)
STRIPE_PRICE_CREDITS_100=price_100_credits_id
STRIPE_PRICE_CREDITS_500=price_500_credits_id
STRIPE_PRICE_CREDITS_1000=price_1000_credits_id 