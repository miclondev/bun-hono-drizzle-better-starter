# Node environment
NODE_ENV=development
PORT=3005

# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=viralsak
DB_USER=postgres
DB_PASSWORD=postgres

# Better Auth Configuration
# Generate a secure secret: openssl rand -base64 32
BETTER_AUTH_SECRET="P75ZLjuEh0uAMubz8o4M9KqK4LLL"
BETTER_AUTH_URL="http://localhost:3005"

# Google OAuth (Optional)
# Get these from https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email Service (Optional - for password reset emails)
# Using Gmail:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
# Or using SendGrid:
# SENDGRID_API_KEY=your_sendgrid_api_key
# Or using Resend:
# RESEND_API_KEY=your_resend_api_key

# TikTok OAuth Configuration
# Get these from https://developers.tiktok.com
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=http://localhost:3005/api/v1/tiktok/oauth/callback
FRONTEND_URL=http://localhost:5173

# Anthropic API Configuration
# Get your API key from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key 